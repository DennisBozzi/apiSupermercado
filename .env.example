# ===== ASP.NET Core =====
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ===== Database (PostgreSQL / Neon) =====
# Use the POOLER endpoint for Neon. Switch branches (dev/qa/prod) by changing this string only.
Database__ConnectionString=Host=<host>.neon.tech;Port=5432;Database=<db>;Username=<user>;Password=<YOUR_PASSWORD_HERE>;Ssl Mode=Require;Trust Server Certificate=true
Database__EnableRetryOnFailure=true
Database__MaxRetryCount=5

# ===== Firebase (Auth + Storage) =====
Firebase__ProjectId=<YOUR_FIREBASE_PROJECT_ID>
Firebase__StorageBucket=<YOUR_FIREBASE_PROJECT_ID>.appspot.com

# Service account credentials. Use EITHER CredentialsPath (recommended) OR CredentialsJson.
#
# Option 1 — Path to the JSON file (recommended, no env-parsing issues):
#   - Save the service-account JSON inside ./secrets/ at the repo root (gitignored).
#   - Local dev (dotnet run from repo root): the relative path below resolves to <repo>/secrets/firebase.json.
#   - Docker: ./secrets is mounted at /app/secrets inside the container (WORKDIR=/app),
#     so the same relative path "secrets/firebase.json" works in both contexts.
Firebase__CredentialsPath=secrets/firebase.json
#
# Option 2 — Inline JSON, single line (fallback). Comment out CredentialsPath above to use this.
#   - No surrounding quotes.
#   - Keep \n inside "private_key" as literal \n (two characters), do NOT use real newlines.
#Firebase__CredentialsJson={"type":"service_account","project_id":"<project>","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# ===== CORS =====
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:3000
